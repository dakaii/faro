# Copy to .env and fill in.
# With Docker Compose: only ETHERSCAN_API_KEY is required; NEO4J_* are set by compose.
# Local dev: set all if using Neo4j (or omit NEO4J_* to run without graph).
ETHERSCAN_API_KEY=your_etherscan_api_key
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# Copy to .env and fill in.
# With Docker Compose: only ETHERSCAN_API_KEY is required; NEO4J_* are set by compose.
# Local dev: set all if using Neo4j (or omit NEO4J_* to run without graph).
# Optional: CORS_ORIGINS=https://app.example.com (comma-separated; default allows localhost:5173,3000)
ETHERSCAN_API_KEY=your_etherscan_api_key
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# LLM & embeddings (OpenAI-compatible). Omit to use heuristic-only.
OPENAI_API_KEY=
# Optional: use another provider (OpenRouter, self-hosted). Same key or provider key.
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_LLM_MODEL=gpt-4o-mini
